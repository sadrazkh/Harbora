{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=harbora;Username=harbora;Password=harbora"
  },
  "Harbora": {
    "MasterKey": "dev-insecure-master-key-change-me-in-production"
  },
  "Docker": {
    "Host": ""
  },
  "Traefik": {
    "DynamicConfigPath": "/etc/harbora/traefik/dynamic/harbora.yml",
    "CertResolver": "letsencrypt",
    "EntryPointWeb": "web",
    "EntryPointWebSecure": "websecure"
  },
  "Runtime": {
    "WorkDir": "/var/lib/harbora/builds",
    "Network": "harbora",
    "ImagePrefix": "harbora",
    "RootDomain": "localhost"
  },
  "Vite": {
    "UseDevServer": false,
    "DevServerUrl": "http://localhost:5173"
  }
}
