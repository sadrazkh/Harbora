{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=harbora;Username=harbora;Password=harbora"
  },
  "Harbora": {
    "_comment": "MasterKey MUST be supplied via the HARBORA_MASTER_KEY env var in production (the installer generates it in deploy/.env). Left blank here so the app fails closed if it is missing.",
    "MasterKey": ""
  },
  "Docker": {
    "Host": ""
  },
  "Traefik": {
    "DynamicConfigPath": "/etc/harbora/traefik/dynamic/harbora.yml",
    "CertResolver": "letsencrypt",
    "EntryPointWeb": "web",
    "EntryPointWebSecure": "websecure"
  },
  "Runtime": {
    "WorkDir": "/var/lib/harbora/builds",
    "Network": "harbora",
    "ImagePrefix": "harbora",
    "RootDomain": "localhost"
  },
  "Backups": {
    "StagingDir": "/var/lib/harbora/backups",
    "StagingVolume": "harbora_backups",
    "HelperImage": "alpine:3.20",
    "DefaultRetentionCount": 7
  },
  "Vite": {
    "UseDevServer": false,
    "DevServerUrl": "http://localhost:5173"
  }
}
