@model CreateAppViewModel
@{
    ViewData["Title"] = "Create Application";
    var isFa = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fa";
    var sizes = ViewBag.Sizes as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var servers = ViewBag.Servers as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var input = "w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:outline-none";
}
<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-1">@(isFa ? "استقرار اپ جدید" : "Deploy a new app")</h1>
    <p class="text-slate-400 text-sm mb-6">@(isFa ? "فقط یک نام و منبع بده — بقیه را خودمان می‌سازیم." : "Just a name and a source — we handle the rest.")</p>

    <form asp-controller="Apps" asp-action="Create" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="rounded-lg bg-red-900/30 border border-red-700 text-red-300 px-4 py-2 text-sm"></div>

        <div>
            <label class="block text-sm text-slate-400 mb-1">@T["Name"]</label>
            <input asp-for="Name" required autofocus placeholder="@(isFa ? "مثلاً وب‌سایت من" : "My website")" class="@input" />
        </div>

        @* ---- Source as visual cards ---- *@
        <div>
            <label class="block text-sm text-slate-400 mb-2">@T["Source"]</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <label class="cursor-pointer rounded-xl border border-slate-800 bg-slate-900/60 p-4 has-[:checked]:border-brand-500 has-[:checked]:ring-1 has-[:checked]:ring-brand-500">
                    <input class="sr-only" type="radio" asp-for="SourceType" value="GitRepository" data-src checked />
                    <div class="text-2xl">🐙</div>
                    <div class="mt-1 font-semibold">@(isFa ? "مخزن Git" : "Git repository")</div>
                    <div class="text-xs text-slate-500">@(isFa ? "با Dockerfile یا بدون آن (تشخیص خودکار)" : "With a Dockerfile or none (auto-detected)")</div>
                </label>
                <label class="cursor-pointer rounded-xl border border-slate-800 bg-slate-900/60 p-4 has-[:checked]:border-brand-500 has-[:checked]:ring-1 has-[:checked]:ring-brand-500">
                    <input class="sr-only" type="radio" asp-for="SourceType" value="PrebuiltImage" data-src />
                    <div class="text-2xl">📦</div>
                    <div class="mt-1 font-semibold">@(isFa ? "ایمیج Docker" : "Docker image")</div>
                    <div class="text-xs text-slate-500">@(isFa ? "یک ایمیج آماده اجرا کن" : "Run a prebuilt image")</div>
                </label>
                <label class="cursor-pointer rounded-xl border border-slate-800 bg-slate-900/60 p-4 has-[:checked]:border-brand-500 has-[:checked]:ring-1 has-[:checked]:ring-brand-500">
                    <input class="sr-only" type="radio" asp-for="SourceType" value="StaticSite" data-src />
                    <div class="text-2xl">📄</div>
                    <div class="mt-1 font-semibold">@(isFa ? "سایت استاتیک" : "Static site")</div>
                    <div class="text-xs text-slate-500">@(isFa ? "از مخزن Git، پشت Nginx" : "From a Git repo, served by Nginx")</div>
                </label>
            </div>
        </div>

        @* ---- Essential field per source ---- *@
        <div data-panel="GitRepository,StaticSite">
            <label class="block text-sm text-slate-400 mb-1">@(isFa ? "آدرس Git" : "Git repository URL")</label>
            <input asp-for="CloneUrl" placeholder="https://github.com/user/repo.git" class="@input" />
        </div>
        <div data-panel="PrebuiltImage" style="display:none">
            <label class="block text-sm text-slate-400 mb-1">@(isFa ? "ایمیج" : "Image")</label>
            <input asp-for="PrebuiltImage" placeholder="nginx:alpine" class="@input" />
        </div>

        @* ---- Advanced (collapsed) ---- *@
        <details class="rounded-xl border border-slate-800 bg-slate-900/40 px-4 py-3">
            <summary class="cursor-pointer text-sm font-medium text-slate-300">@(isFa ? "تنظیمات پیشرفته (اختیاری)" : "Advanced settings (optional)")</summary>
            <div class="mt-4 space-y-4">
                <div class="grid sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm text-slate-400 mb-1">Slug</label>
                        <input asp-for="Slug" placeholder="@(isFa ? "خودکار از نام" : "auto from name")" class="@input" />
                    </div>
                    <div data-panel="GitRepository,StaticSite">
                        <label class="block text-sm text-slate-400 mb-1">@T["Branch or Tag"]</label>
                        <input asp-for="GitRef" class="@input" />
                    </div>
                </div>

                <div data-panel="GitRepository,StaticSite" class="grid sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm text-slate-400 mb-1">@(isFa ? "توکن دسترسی (مخزن خصوصی)" : "Access token (private repo)")</label>
                        <input asp-for="GitToken" type="password" class="@input" />
                    </div>
                    <div data-panel="GitRepository">
                        <label class="block text-sm text-slate-400 mb-1">Dockerfile path</label>
                        <input asp-for="DockerfilePath" class="@input" />
                        <span class="text-xs text-slate-500">@(isFa ? "نبود؟ استک خودکار تشخیص داده می‌شود." : "None? The stack is auto-detected.")</span>
                    </div>
                </div>

                @if (sizes.Count > 0)
                {
                    <div>
                        <label class="block text-sm text-slate-400 mb-1">@(isFa ? "اندازه‌ی منبع" : "Instance size")</label>
                        <select asp-for="InstanceSizeKey" asp-items="sizes" class="@input"></select>
                    </div>
                }

                <div class="grid sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm text-slate-400 mb-1">@(isFa ? "پورت کانتینر" : "Container port")</label>
                        <input asp-for="ContainerPort" type="number" class="@input" />
                    </div>
                    <div>
                        <label class="block text-sm text-slate-400 mb-1">@T["Domain"]</label>
                        <input asp-for="Domain" placeholder="@(isFa ? "خودکار: slug.دامنه‌ی‌شما" : "auto: slug.your-domain")" class="@input" />
                    </div>
                </div>

                @if (servers.Count > 1)
                {
                    <div>
                        <label class="block text-sm text-slate-400 mb-1">@(isFa ? "سرور" : "Server")</label>
                        <select asp-for="ServerId" asp-items="servers" class="@input"></select>
                    </div>
                }
            </div>
        </details>

        <label class="flex items-center gap-2 text-sm">
            <input asp-for="DeployNow" type="checkbox" />
            @(isFa ? "همین حالا بساز و دیپلوی کن (رفتن به لاگ زنده)" : "Build & deploy now (go to live logs)")
        </label>

        <div class="flex gap-3">
            <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-500 px-6 py-2.5 font-semibold">@(isFa ? "ایجاد و استقرار" : "Create & deploy")</button>
            <a href="/apps" class="rounded-lg bg-slate-800 hover:bg-slate-700 px-5 py-2.5">@T["Cancel"]</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    // Show only the fields relevant to the selected source.
    function syncSource() {
        var val = document.querySelector('[data-src]:checked')?.value || 'GitRepository';
        document.querySelectorAll('[data-panel]').forEach(function (el) {
            var list = el.getAttribute('data-panel').split(',').map(function (s) { return s.trim(); });
            el.style.display = list.indexOf(val) >= 0 ? '' : 'none';
        });
    }
    document.querySelectorAll('[data-src]').forEach(function (r) { r.addEventListener('change', syncSource); });
    syncSource();
</script>
}
