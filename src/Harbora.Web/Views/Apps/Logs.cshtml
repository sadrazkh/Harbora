@model App
@{
    ViewData["Title"] = Model.Name + " · Logs";
    var isFa = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fa";
}
<div class="mb-4 flex items-center justify-between">
    <div>
        <a href="/apps/details/@Model.Id" class="text-brand-400 text-sm">← @Model.Name</a>
        <h1 class="text-2xl font-bold">@(isFa ? "لاگ‌های کانتینر" : "Container logs")</h1>
    </div>
    <label class="flex items-center gap-2 text-sm text-slate-400">
        <input type="checkbox" id="autorefresh" checked> @(isFa ? "به‌روزرسانی خودکار" : "Auto-refresh")
    </label>
</div>

<div class="rounded-xl border border-slate-800 bg-black/70 font-mono text-xs">
    <div class="flex items-center justify-between px-4 py-2 border-b border-slate-800 text-slate-400">
        <span>harbora-@Model.Slug</span>
        <button id="clear" class="hover:text-white">clear</button>
    </div>
    <pre id="log" class="p-4 max-h-[70vh] overflow-auto whitespace-pre-wrap">@(isFa ? "در حال بارگذاری…" : "Loading…")</pre>
</div>

@section Scripts {
<script>
    const el = document.getElementById('log');
    const auto = document.getElementById('autorefresh');
    document.getElementById('clear').onclick = () => { el.textContent = ''; };
    let atBottom = true;
    el.parentElement.addEventListener('scroll', () => {
        atBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 40;
    });
    async function load() {
        try {
            const r = await fetch('/apps/@Model.Id/logs/data?tail=400');
            const t = await r.text();
            el.textContent = t || '@(isFa ? "لاگی موجود نیست (کانتینر در حال اجرا نیست)." : "No logs (container not running).")';
            if (atBottom) el.scrollTop = el.scrollHeight;
        } catch (e) { /* keep last */ }
    }
    load();
    setInterval(() => { if (auto.checked) load(); }, 3000);
</script>
}
