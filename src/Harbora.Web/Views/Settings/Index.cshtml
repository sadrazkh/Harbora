@model List<Harbora.Domain.Settings.Setting>
@{
    ViewData["Title"] = "Settings";
    var tokens = ViewBag.Tokens as List<Harbora.Domain.Identity.ApiToken> ?? new();
    var newToken = TempData["NewToken"] as string;
}
<h1 class="text-2xl font-bold mb-6">@T["Settings"]</h1>

<div class="grid lg:grid-cols-2 gap-6">
    <section class="rounded-xl border border-slate-800 bg-slate-900/60 divide-y divide-slate-800">
        <div class="px-4 py-3 font-semibold border-b border-slate-800">Platform</div>
        @foreach (var s in Model)
        {
            <div class="flex items-center justify-between p-4">
                <span class="font-mono text-sm text-slate-300">@s.Key</span>
                <span class="text-sm text-slate-400">@s.Value</span>
            </div>
        }
    </section>

    <section class="rounded-xl border border-slate-800 bg-slate-900/60">
        <div class="px-4 py-3 font-semibold border-b border-slate-800">@T["API Tokens"]</div>
        <div class="p-4 space-y-4">
            @if (newToken is not null)
            {
                <div class="rounded-lg bg-emerald-900/20 border border-emerald-700 p-3 text-sm">
                    <div class="text-emerald-300 mb-1">Copy this token now — it won't be shown again.</div>
                    <code class="block break-all text-emerald-200">@newToken</code>
                </div>
            }
            <form asp-controller="Settings" asp-action="CreateToken" method="post" class="flex gap-2">
                @Html.AntiForgeryToken()
                <input name="name" placeholder="Token name" class="flex-1 rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
                <button class="rounded-lg bg-brand-600 hover:bg-brand-500 px-4 py-2 text-sm font-semibold">Create</button>
            </form>
            <div class="divide-y divide-slate-800">
                @foreach (var t in tokens)
                {
                    <div class="flex items-center justify-between py-2 text-sm">
                        <span>@t.Name <span class="text-slate-500 font-mono">@t.Prefix…</span></span>
                        <span class="text-xs text-slate-500">@t.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd")</span>
                    </div>
                }
            </div>
        </div>
    </section>
</div>
