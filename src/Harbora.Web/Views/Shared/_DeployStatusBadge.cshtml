@model Harbora.Domain.Common.DeploymentStatus
@{
    var (cls, label) = Model switch
    {
        DeploymentStatus.Succeeded => ("bg-emerald-500/15 text-emerald-400", T["Succeeded"].Value),
        DeploymentStatus.Failed => ("bg-red-500/15 text-red-400", T["Failed"].Value),
        DeploymentStatus.Cancelled => ("bg-slate-500/15 text-slate-300", "Cancelled"),
        DeploymentStatus.RolledBack => ("bg-amber-500/15 text-amber-300", T["Rollback"].Value),
        _ => ("bg-brand-500/15 text-brand-300 animate-pulse", Model.ToString())
    };
}
<span class="rounded-full px-2.5 py-0.5 text-xs font-medium @cls">@label</span>
