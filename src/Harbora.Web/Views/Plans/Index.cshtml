@model PlansPageViewModel
@{
    ViewData["Title"] = "Plans";
    var isFa = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fa";
    var u = Model.Usage;
    string Mb(long b) => b <= 0 ? "∞" : $"{b / 1024 / 1024} MB";
    string Bar(double used, double max)
    {
        if (max <= 0) return "5";
        var pct = Math.Min(100, used / max * 100);
        return pct.ToString("0");
    }
}
<h1 class="text-2xl font-bold mb-1">@(isFa ? "پلن و مصرف" : "Plan & Usage")</h1>
<p class="text-slate-400 text-sm mb-6">@(isFa ? "پلن فعلی:" : "Current plan:") <span class="text-slate-200 font-medium">@u.PlanName</span>
    @if (u.Suspended){<span class="ms-2 text-xs rounded bg-red-500/15 text-red-400 px-2 py-0.5">@(isFa ? "معلق" : "suspended")</span>}
</p>

<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    @{
        (string label, string used, double u1, double m1)[] cards =
        {
            (isFa ? "اپلیکیشن‌ها" : "Apps", $"{u.Apps} / {(u.MaxApps == 0 ? "∞" : u.MaxApps.ToString())}", u.Apps, u.MaxApps),
            (isFa ? "سرویس‌ها" : "Services", $"{u.Services} / {(u.MaxServices == 0 ? "∞" : u.MaxServices.ToString())}", u.Services, u.MaxServices),
            (isFa ? "حافظه" : "Memory", $"{Mb(u.MemoryUsedBytes)} / {Mb(u.MaxMemoryBytes)}", u.MemoryUsedBytes, u.MaxMemoryBytes),
            ("CPU", $"{u.CpuUsed:0.##} / {(u.MaxCpuCores == 0 ? "∞" : u.MaxCpuCores.ToString("0.##"))}", u.CpuUsed, u.MaxCpuCores),
        };
    }
    @foreach (var c in cards)
    {
        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
            <div class="text-slate-400 text-sm">@c.label</div>
            <div class="mt-1 text-xl font-bold">@c.used</div>
            <div class="mt-2 h-1.5 rounded-full bg-slate-800 overflow-hidden">
                <div class="h-full bg-brand-500" style="width:@(Bar(c.u1, c.m1))%"></div>
            </div>
        </div>
    }
</div>

<h2 class="text-lg font-semibold mb-3">@(isFa ? "پلن‌های ارائه‌شده" : "Offered plans")</h2>
<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    @foreach (var p in Model.Plans)
    {
        <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
            <div class="flex items-center justify-between">
                <span class="font-semibold text-lg">@(isFa ? p.NameFa : p.Name)</span>
                @if (p.MonthlyPrice > 0){<span class="text-brand-400 font-semibold">$@p.MonthlyPrice<span class="text-xs text-slate-500">/mo</span></span>}
            </div>
            <ul class="mt-3 space-y-1 text-sm text-slate-400">
                <li>@(p.MaxApps == 0 ? (isFa ? "اپ نامحدود" : "Unlimited apps") : $"{p.MaxApps} apps")</li>
                <li>@(p.MaxServices == 0 ? (isFa ? "سرویس نامحدود" : "Unlimited services") : $"{p.MaxServices} services")</li>
                <li>@(isFa ? "حافظه:" : "Memory:") @Mb(p.MaxMemoryBytes)</li>
                <li>@(isFa ? "پردازنده:" : "CPU:") @(p.MaxCpuCores == 0 ? "∞" : p.MaxCpuCores.ToString("0.##"))</li>
                @if (!string.IsNullOrWhiteSpace(p.AllowedSizeKeys)){<li>@(isFa ? "اندازه‌ها:" : "Sizes:") @p.AllowedSizeKeys</li>}
            </ul>
        </div>
    }
</div>

<h2 class="text-lg font-semibold mb-3">@(isFa ? "اندازه‌های منبع" : "Instance sizes")</h2>
<div class="rounded-xl border border-slate-800 bg-slate-900/60 divide-y divide-slate-800 mb-8">
    @foreach (var s in Model.Sizes)
    {
        <div class="flex items-center justify-between p-3 text-sm">
            <span class="font-medium">@(isFa ? s.NameFa : s.Name) <span class="text-slate-500 font-mono">@s.Key</span></span>
            <span class="text-slate-400">@s.CpuCores vCPU · @(s.MemoryBytes / 1024 / 1024) MB</span>
        </div>
    }
</div>

@if (Model.IsProvider)
{
    <section class="rounded-xl border border-slate-800 bg-slate-900/60 p-5 max-w-2xl">
        <h2 class="font-semibold mb-3">@(isFa ? "ساخت پلن جدید" : "Create a plan")</h2>
        <form asp-controller="Plans" asp-action="CreatePlan" method="post" class="grid sm:grid-cols-2 gap-3">
            @Html.AntiForgeryToken()
            <input name="name" placeholder="Name" class="rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
            <input name="monthlyPrice" type="number" step="0.01" placeholder="Price /mo" class="rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
            <input name="maxApps" type="number" value="1" placeholder="Max apps" class="rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
            <input name="maxServices" type="number" value="1" placeholder="Max services" class="rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
            <input name="maxMemoryMb" type="number" value="1024" placeholder="Max memory (MB)" class="rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
            <input name="maxCpu" type="number" step="0.25" value="1" placeholder="Max CPU cores" class="rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm" />
            <input name="allowedSizeKeys" placeholder="nano,micro,small" class="sm:col-span-2 rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-sm font-mono" />
            <div class="sm:col-span-2"><button class="rounded-lg bg-brand-600 hover:bg-brand-500 px-4 py-2 text-sm font-semibold">@(isFa ? "ذخیره" : "Save")</button></div>
        </form>
        <p class="mt-2 text-xs text-slate-500">@(isFa ? "۰ یعنی نامحدود." : "0 means unlimited.")</p>
    </section>
}
