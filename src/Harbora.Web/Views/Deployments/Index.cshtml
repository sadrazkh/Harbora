@model List<Harbora.Domain.Deployments.Deployment>
@{
    ViewData["Title"] = "Deployments";
    var isFa = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fa";
    string Dur(Harbora.Domain.Deployments.Deployment d)
    {
        if (d.StartedAt is null || d.FinishedAt is null) return "—";
        var s = (d.FinishedAt.Value - d.StartedAt.Value).TotalSeconds;
        return s < 60 ? $"{s:0}s" : $"{s / 60:0.0}m";
    }
}
<h1 class="text-2xl font-bold mb-6">@T["Deployments"]</h1>

@if (Model.Count == 0)
{
    <div class="rounded-xl border border-dashed border-slate-700 p-12 text-center text-slate-400">
        @(isFa ? "هنوز استقراری انجام نشده است." : "No deployments yet.")
    </div>
}
else
{
    <div class="rounded-xl border border-slate-800 bg-slate-900/60 overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="text-slate-400 border-b border-slate-800">
                <tr>
                    <th class="p-3 text-start">@T["Applications"]</th>
                    <th class="p-3 text-start">#</th>
                    <th class="p-3 text-start">@T["Status"]</th>
                    <th class="p-3 text-start">@(isFa ? "منبع" : "Trigger")</th>
                    <th class="p-3 text-start">Commit</th>
                    <th class="p-3 text-start">@(isFa ? "مدت" : "Duration")</th>
                    <th class="p-3 text-start">@(isFa ? "زمان" : "Time")</th>
                    <th class="p-3 text-end"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
                @foreach (var d in Model)
                {
                    <tr class="hover:bg-slate-800/30">
                        <td class="p-3"><a href="/apps/details/@d.AppId" class="hover:text-brand-400">@d.App?.Name</a></td>
                        <td class="p-3 text-slate-400">#@d.Number</td>
                        <td class="p-3"><partial name="_DeployStatusBadge" model="d.Status" /></td>
                        <td class="p-3 text-slate-400">@d.Trigger</td>
                        <td class="p-3 font-mono text-xs">
                            @if (d.CommitSha is not null)
                            {
                                <span title="@d.CommitMessage">@d.GitRef @@ @d.CommitSha[..Math.Min(7, d.CommitSha.Length)]</span>
                            }
                            else { <span class="text-slate-600">—</span> }
                        </td>
                        <td class="p-3 text-slate-400">@Dur(d)</td>
                        <td class="p-3 text-slate-500 text-xs">@d.CreatedAt.LocalDateTime.ToString("MM/dd HH:mm")</td>
                        <td class="p-3 text-end"><a href="/deployments/details/@d.Id" class="text-xs text-brand-400">@T["Logs"]</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
