@model List<Harbora.Domain.Services.ManagedService>
@{
    ViewData["Title"] = "Databases";
    string StatusClass(Harbora.Domain.Common.ServiceStatus s) => s switch
    {
        Harbora.Domain.Common.ServiceStatus.Running => "bg-emerald-500/15 text-emerald-400",
        Harbora.Domain.Common.ServiceStatus.Failed => "bg-red-500/15 text-red-400",
        Harbora.Domain.Common.ServiceStatus.Provisioning => "bg-brand-500/15 text-brand-300 animate-pulse",
        _ => "bg-slate-500/15 text-slate-300"
    };
}
<div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold">@T["Databases"]</h1>
    <a href="/databases/create" class="rounded-lg bg-brand-600 hover:bg-brand-500 px-4 py-2 text-sm font-semibold">+ @T["New Service"]</a>
</div>

@if (Model.Count == 0)
{
    <div class="rounded-xl border border-dashed border-slate-700 p-12 text-center">
        <p class="text-lg font-medium">@T["No services yet"]</p>
        <a href="/databases/create" class="mt-4 inline-block rounded-lg bg-brand-600 hover:bg-brand-500 px-4 py-2 text-sm font-semibold">@T["Create Service"]</a>
    </div>
}
else
{
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var s in Model)
        {
            <a href="/databases/@s.Id" class="rounded-xl border border-slate-800 bg-slate-900/60 p-5 hover:border-brand-600 transition">
                <div class="flex items-center justify-between">
                    <span class="font-semibold text-lg">@s.Name</span>
                    <span class="rounded-full px-2.5 py-0.5 text-xs font-medium @StatusClass(s.Status)">@s.Status</span>
                </div>
                <div class="mt-2 text-sm text-slate-400">@s.Type · @s.Version</div>
                <div class="mt-1 text-xs text-slate-500 font-mono">@s.ContainerName:@s.InternalPort</div>
            </a>
        }
    </div>
}
