@model CreateServiceViewModel
@{
    ViewData["Title"] = "New service";
    var catalog = ViewBag.Catalog as IReadOnlyList<Harbora.Application.Abstractions.ServiceCatalogEntry> ?? new List<Harbora.Application.Abstractions.ServiceCatalogEntry>();
    var isFa = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fa";
    var versionMap = catalog.ToDictionary(c => c.Type.ToString(), c => c.Versions);
}
<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">@T["New Service"]</h1>

    <form asp-controller="Databases" asp-action="Create" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="rounded-lg bg-red-900/30 border border-red-700 text-red-300 px-4 py-2 text-sm"></div>

        <div>
            <label class="block text-sm text-slate-400 mb-2">@T["Type"]</label>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                @foreach (var c in catalog)
                {
                    <label class="cursor-pointer rounded-xl border border-slate-800 bg-slate-900/60 p-4 has-[:checked]:border-brand-500 has-[:checked]:bg-slate-900">
                        <input class="sr-only" type="radio" asp-for="Type" value="@c.Type" data-type-radio />
                        <div class="font-semibold">@(isFa ? c.DisplayNameFa : c.DisplayName)</div>
                        <div class="text-xs text-slate-500 mt-1">port @c.InternalPort</div>
                    </label>
                }
            </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm text-slate-400 mb-1">@T["Name"]</label>
                <input asp-for="Name" placeholder="my-database" class="w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2" />
            </div>
            <div>
                <label class="block text-sm text-slate-400 mb-1">@T["Version"]</label>
                <select asp-for="Version" data-version class="w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2"></select>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="rounded-lg bg-brand-600 hover:bg-brand-500 px-5 py-2 font-semibold">@T["Create Service"]</button>
            <a href="/databases" class="rounded-lg bg-slate-800 hover:bg-slate-700 px-5 py-2">@T["Cancel"]</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    const versions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(versionMap));
    const versionSel = document.querySelector('[data-version]');
    function fillVersions() {
        const t = document.querySelector('[data-type-radio]:checked')?.value;
        const list = versions[t] || [];
        versionSel.innerHTML = list.map(v => `<option value="${v}">${v}</option>`).join('');
    }
    document.querySelectorAll('[data-type-radio]').forEach(r => r.addEventListener('change', fillVersions));
    // default-select the first type
    const first = document.querySelector('[data-type-radio]');
    if (first) { first.checked = true; fillVersions(); }
</script>
}
